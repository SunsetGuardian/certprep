---
layout: layouts/base.njk
pagination:
  data: pagedQuiz.questionPositions
  size: 1
  alias: questionPosition
eleventyComputed:
  title: "Security+ SY0-701 Practice Test Question {{ questionPosition }}"
  description: "Reserved route for question {{ questionPosition }} in the Cert Happens paged Security+ SY0-701 practice-test pilot."
  permalink: "/security-plus/sy0-701/practice-test/question/{{ questionPosition }}/index.html"
robots: noindex,nofollow,nosnippet
sitemap: false
---
<nav class="breadcrumbs page-shell" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    <li><a href="/security-plus/">Security+</a></li>
    <li><a href="/security-plus/sy0-701/practice-test/?mode=classic">SY0-701 practice test</a></li>
    <li aria-current="page">Question {{ questionPosition }}</li>
  </ol>
</nav>

<section
  class="page-shell content-section paged-quiz"
  data-paged-question-app
  data-test-id="SEC-701"
  data-question-position="{{ questionPosition }}"
>
  <p class="eyebrow">Paged quiz pilot</p>
  <h1 class="paged-quiz__title">Security+ SY0-701 question {{ questionPosition }}</h1>

  <div data-paged-view="restored" hidden>
    <header class="paged-quiz__header">
      <p>
        <strong data-paged-position>Question {{ questionPosition }}</strong>
        <span aria-hidden="true"> · </span>
        <code data-paged-question-id></code>
      </p>

      <p data-paged-summary>Restoring progress…</p>

      <progress
        class="paged-quiz__progress"
        data-paged-progress
        value="{{ questionPosition }}"
        max="50"
      >
        Question {{ questionPosition }}
      </progress>
    </header>

    <nav class="paged-quiz__navigator" aria-label="Questions in this practice test">
      <ol class="quiz-navigator__grid" data-paged-navigator></ol>
    </nav>

    <p>
      <span data-paged-domain></span>
      <span aria-hidden="true"> · </span>
      <span data-paged-topic></span>
    </p>

    <h2 class="paged-quiz__question-heading" data-paged-question-text>Restoring saved question…</h2>
    <p data-paged-instruction hidden></p>

    <form class="quiz-answer-form">
      <fieldset>
        <legend class="visually-hidden">Select your answer</legend>
        <div class="quiz-answers" data-paged-answers></div>
      </fieldset>
    </form>

    <p>
      Browser-session answer state:
      <strong data-paged-answer-status></strong>.
    </p>

    <p class="visually-hidden" aria-live="polite" data-paged-live></p>

    <nav class="paged-quiz__controls" aria-label="Previous and next question">
      <a
        class="button button--secondary"
        data-paged-previous
      >
        Previous
      </a>

      <a
        class="button"
        data-paged-next
      >
        Next
      </a>
    </nav>

    <p>
      Each numbered link performs a full document navigation while preserving
      this randomized test in the current browser tab.
    </p>

    <p>
      <a class="button-link" href="/security-plus/sy0-701/practice-test/?mode=classic">
        Open the single-page fallback
      </a>
    </p>
  </div>

  <div data-paged-view="unavailable">
    <h2 data-paged-unavailable-heading>
      Checking this browser tab for an active test…
    </h2>
    <p data-paged-unavailable-detail>
      The numbered route only restores a test previously started in this tab.
    </p>
    <p>
      <a class="button-link" href="/security-plus/sy0-701/practice-test/?mode=classic">
        Open the single-page fallback
      </a>
    </p>
  </div>

  <noscript>
    <p>JavaScript is required to restore a saved practice-test session.</p>
  </noscript>
</section>

<script type="module" src="/assets/js/quiz/paged-question.js"></script>
