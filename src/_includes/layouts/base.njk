<!doctype html>
<html lang="{{ site.language }}">
<head>
  {% set pageDescription = description or site.description %}
  {% set canonicalUrl = site.url ~ page.url %}
  {% set socialImageUrl = site.url ~ site.socialImagePath %}
  {% set fullTitle = title %}
  {% if title != site.name %}
    {% set fullTitle = title ~ " | " ~ site.name %}
  {% endif %}

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark light">
  <meta name="theme-color" content="#10141d">

  <title>{{ fullTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">
  <meta name="robots" content="{{ robots or 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1' }}">
  <link rel="canonical" href="{{ canonicalUrl }}">

  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="{{ site.locale }}">
  <meta property="og:title" content="{{ fullTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:image" content="{{ socialImageUrl }}">
  <meta property="og:image:width" content="{{ site.socialImageWidth }}">
  <meta property="og:image:height" content="{{ site.socialImageHeight }}">
  <meta property="og:image:alt" content="CertHappens.com certification practice and study resources">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ fullTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ socialImageUrl }}">

  <link rel="icon" href="/assets/brand/favicon-v2.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand/favicon-32-v2.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/brand/favicon-16-v2.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/brand/apple-touch-icon-v2.png">
  <link rel="manifest" href="/site.webmanifest">

  <link rel="stylesheet" href="/assets/css/site.css">
  <link rel="stylesheet" href="/assets/css/brand.css">
  <link rel="stylesheet" href="/assets/css/phase6.css">
  {% if printable %}
  <link rel="stylesheet" href="/assets/css/print.css" media="print">
  {% endif %}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ site.url }}/#organization",
        "name": {{ site.name | json | safe }},
        "url": {{ site.url | json | safe }},
        "logo": {
          "@type": "ImageObject",
          "url": {{ (site.url ~ site.logoPath) | json | safe }}
        }
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": {{ site.url | json | safe }},
        "name": {{ site.name | json | safe }},
        "description": {{ site.description | json | safe }},
        "publisher": {
          "@id": "{{ site.url }}/#organization"
        },
        "inLanguage": {{ site.language | json | safe }}
      },
      {
        "@type": "WebPage",
        "@id": "{{ canonicalUrl }}#webpage",
        "url": {{ canonicalUrl | json | safe }},
        "name": {{ fullTitle | json | safe }},
        "description": {{ pageDescription | json | safe }},
        "isPartOf": {
          "@id": "{{ site.url }}/#website"
        },
        "inLanguage": {{ site.language | json | safe }}
      }
      {% if page.url == "/security-plus/" %},
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ site.url }}/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Security+",
            "item": "{{ site.url }}/security-plus/"
          }
        ]
      }
      {% elif page.url == "/security-plus/sy0-701/practice-test/" %},
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ site.url }}/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Security+",
            "item": "{{ site.url }}/security-plus/"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "SY0-701 practice test",
            "item": "{{ site.url }}/security-plus/sy0-701/practice-test/"
          }
        ]
      }
      {% elif page.url == "/privacy/" or page.url == "/terms/" or page.url == "/disclaimer/" or page.url == "/contact/" %},
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ site.url }}/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ title | json | safe }},
            "item": {{ canonicalUrl | json | safe }}
          }
        ]
      }
      {% endif %}
    ]
  }
  </script>
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <header class="site-header">
    <div class="site-header__inner page-shell">
      <a class="site-brand" href="/" aria-label="{{ site.name }} home">
        <img
          class="site-brand__logo"
          src="/assets/brand/certhappens-header-mark-v2.png"
          width="640"
          height="451"
          alt=""
          aria-hidden="true"
        >
        <span class="site-brand__wordmark" aria-hidden="true">
          <span class="site-brand__cert">Cert</span><span class="site-brand__happens">Happens</span><span class="site-brand__dotcom">.com</span>
        </span>
      </a>

      {% if printable %}
      <span class="site-header__print-title" aria-hidden="true">{{ printTitle or title }}</span>
      {% endif %}

      <nav class="primary-nav" aria-label="Primary navigation">
        {% for item in siteNavigation.primary %}
        <a href="{{ item.url }}">{{ item.label }}</a>
        {% endfor %}
      </nav>
    </div>
  </header>

  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="page-shell site-footer__inner">
      <nav class="site-footer__nav" aria-label="Footer navigation">
        {% for item in siteNavigation.footer %}
        <a href="{{ item.url }}">{{ item.label }}</a>
        {% endfor %}
      </nav>
      <p>&copy; {{ "" | currentYear }} {{ site.name }}.</p>
      <p class="site-footer__disclaimer">
        This independent study resource is not affiliated with or endorsed by CompTIA.
        CompTIA and Security+ are trademarks of CompTIA, Inc.
      </p>
    </div>
  </footer>
</body>
</html>
