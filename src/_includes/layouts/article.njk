---
layout: layouts/base.njk
---
{% set articleAuthorKey = author or "certHappens" %}
{% set articleAuthor = authors[articleAuthorKey] %}
{% set canonicalUrl = site.url ~ page.url %}
{% set publishedDate = datePublished | htmlDateString %}
{% set modifiedDate = (dateModified or datePublished) | htmlDateString %}
{% set articleImageUrl = site.url ~ (socialImagePath or site.socialImagePath) %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title | json | safe }},
  "description": {{ description | json | safe }},
  "datePublished": {{ publishedDate | json | safe }},
  "dateModified": {{ modifiedDate | json | safe }},
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ canonicalUrl | json | safe }}
  },
  "author": {
    "@type": {{ (articleAuthor.type or "Organization") | json | safe }},
    "name": {{ articleAuthor.name | json | safe }},
    "url": {{ (site.url ~ articleAuthor.url) | json | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | json | safe }},
    "url": {{ site.url | json | safe }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ (site.url ~ site.logoPath) | json | safe }}
    }
  },
  "image": {{ articleImageUrl | json | safe }}{% if articleSection %},
  "articleSection": {{ articleSection | json | safe }}{% endif %}{% if keywords %},
  "keywords": {{ keywords | join(", ") | json | safe }}{% endif %}
}
</script>

{% if breadcrumbs %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {% for crumb in breadcrumbs %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "name": {{ crumb.label | json | safe }},
      "item": {{ (site.url ~ (crumb.url or page.url)) | json | safe }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<header class="page-header page-header--compact article-header">
  <div class="page-shell">
    {% if breadcrumbs %}
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {% for crumb in breadcrumbs %}
        <li{% if loop.last %} aria-current="page"{% endif %}>
          {% if crumb.url and not loop.last %}<a href="{{ crumb.url }}">{{ crumb.label }}</a>{% else %}{{ crumb.label }}{% endif %}
        </li>
        {% endfor %}
      </ol>
    </nav>
    {% endif %}

    {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
    <h1>{{ title }}</h1>
    {% if lede %}<p class="lede">{{ lede }}</p>{% endif %}

    {% if printable %}
    <div class="article-actions">
      <button class="button button--secondary article-print-button" type="button" data-print-guide>
        <svg class="article-print-button__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M7 3h10v5H7V3Zm10 10v8H7v-8h10Zm-2 2H9v4h6v-4Zm3-6a3 3 0 0 1 3 3v5h-2v-2h-1v-4H6v4H5v2H3v-5a3 3 0 0 1 3-3h12Zm-1 2.25a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z" fill="currentColor"/>
        </svg>
        <span>Print / Save PDF</span>
      </button>
    </div>
    {% endif %}
  </div>
</header>

<div class="article-layout page-shell">
  {% if toc %}
  <aside class="article-toc">
    <nav aria-labelledby="article-toc-title">
      <h2 id="article-toc-title">On this page</h2>
      <ol>
        {% for item in toc %}
        <li><a href="#{{ item.id }}">{{ item.label }}</a></li>
        {% endfor %}
      </ol>
    </nav>
  </aside>
  {% endif %}

  <article class="article-body prose">
    {{ content | safe }}

    {% if relatedLinks %}
    <section class="article-related" aria-labelledby="related-resources-title">
      <h2 id="related-resources-title">Related resources</h2>
      <div class="article-related__grid">
        {% for link in relatedLinks %}
        <a class="article-related__item" href="{{ link.url }}">
          <strong>{{ link.title }}</strong>
          {% if link.description %}<span>{{ link.description }}</span>{% endif %}
        </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}
  </article>
</div>

{% if printable %}
<script type="module" src="/assets/js/print-guide.js"></script>
{% endif %}
